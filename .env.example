# ConnectWise API credentials
CW_BASE_URL=https://na.myconnectwise.net/v4_6_release/apis/3.0
CW_COMPANY_ID=yourcompanyid
CW_PUBLIC_KEY=your_public_key
CW_PRIVATE_KEY=your_private_key
CW_CLIENT_ID=your_client_id

# Tool exposure tier
# "leadership" — all 33 tools including finance
# "tech"       — 22 tools, finance omitted from manifest
CW_TIER=leadership

# MCP server auth (optional — omit to disable bearer token requirement)
MCP_AUTH_TOKEN=your_secret_token

# Port (default 8085)
CW_LIVE_MCP_PORT=8085
